{
  "name": "template",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build:stg": "vite build --mode development",
    "build:prod": "vite build --mode production",
    "build": "npm run build:prod && npm run beautify:html",
    "preview": "vite preview --outDir dist/staging --port 4173",
    "beautify:html": "npx js-beautify -f './dist/production/**/*.html' --type html  --no-preserve-newlines --editorconfig",
    "check:js": "biome check src/js/**/*.js",
    "fix:js": "biome check --write src/js/**/*.js",
    "check:css": "stylelint 'src/css/**/*.{css,scss}'",
    "fix:css": "stylelint --fix 'src/css/**/*.{css,scss}'",
    "check:html": "markuplint './dist/production/**/*.html'",
    "check": "concurrently 'npm run check:js' 'npm run check:css' 'npm run check:html' -c '#60a5fa,#663399,#1572eb'",
    "fix": "concurrently 'npm run fix:js' 'npm run fix:css' -c '#60a5fa,#663399'"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.3",
    "@types/node": "^24.2.1",
    "@vituum/vite-plugin-nunjucks": "^1.1.0",
    "browserslist": "^4.25.1",
    "browserslist-config-baseline": "^0.5.0",
    "concurrently": "^9.2.0",
    "js-beautify": "^1.15.4",
    "lightningcss": "^1.30.1",
    "markuplint": "^4.12.0",
    "prettier": "^3.6.2",
    "prettier-plugin-jinja-template": "^2.1.0",
    "sass": "^1.89.2",
    "stylelint": "^16.23.0",
    "stylelint-config-recess-order": "^7.1.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-scss": "^6.12.1",
    "vite": "^6.3.5",
    "vite-plugin-pages": "^0.32.5",
    "vite-plugin-sass-glob-import": "^5.0.0",
    "vituum": "^1.2.0"
  },
  "dependencies": {
    "@solidjs/router": "^0.15.3",
    "@splidejs/splide": "^4.1.4",
    "@vue/compiler-sfc": "^3.5.21",
    "glob": "11.0.3",
    "gsap": "^3.13.0",
    "modern-normalize": "^3.0.1",
    "prettier-plugin-css-order": "^2.1.2",
    "vite-plugin-ssinc": "^1.0.11"
  },
  "browserslist": [
    "extends browserslist-config-baseline"
  ],
  "browserslist-config-baseline": {
    "logConfigToConsole": true
  }
}
